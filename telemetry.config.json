{
  "name": "example_sdk_app",
  "version": "3.0.6",
  "description": "Example editor and renderer for TelemetryOS",
  "mountPoints": {
    "render": "/view",
    "settings": "/edit",
    "home": "/",
    "web": "/example_sdk_app"
  },
  "backgroundWorkers": {
    "background": "workers/background.js"
  },
  "useSpaRouting": true,
  "devServer": {
    "runCommand": "vite --port $PORT",
    "url": "http://localhost:$PORT",
    "readyPattern": "VITE.*ready in"
  }
}
