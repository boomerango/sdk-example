{
  "name": "example_sdk_app",
  "version": "3.0.4",
  "description": "Example editor and renderer for TelemetryOS",
  "mountPoints": {
    "render": "/view",
    "settings": "/edit",
    "home": "/",
    "web": "/example_sdk_app"
  },
    "backgroundWorkers": {
    "background": "workers/background.js"
  },
  "useSpaRouting": true,
  "devServer": {
    "runCommand": "vite --port 3000",
    "url": "http://localhost:3000"
  }
}

